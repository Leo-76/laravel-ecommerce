APP_NAME="Laravel Ecommerce"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

LOG_CHANNEL=stack
LOG_LEVEL=debug

# SQLite par défaut — aucune config requise
DB_CONNECTION=sqlite
# Pour MySQL :
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel_ecommerce
# DB_USERNAME=root
# DB_PASSWORD=

# Pour PostgreSQL :
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=laravel_ecommerce
# DB_USERNAME=postgres
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="boutique@exemple.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ── E-Commerce ────────────────────────────────────────────────────────────────
ECOMMERCE_NOM="Ma Boutique"
ECOMMERCE_EMAIL="boutique@exemple.com"
ECOMMERCE_DEVISE=EUR
ECOMMERCE_SYMBOLE=€

ECOMMERCE_PASSERELLE=stripe
STRIPE_KEY=pk_test_VOTRE_CLE
STRIPE_SECRET=sk_test_VOTRE_CLE
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_SECRET

ECOMMERCE_PREFIX_SHOP=boutique
ECOMMERCE_PREFIX_ADMIN=admin/boutique
ECOMMERCE_LIVRAISON_GRATUITE=5000
ECOMMERCE_LIVRAISON_FORFAIT=490
ECOMMERCE_TVA=20
ECOMMERCE_STOCK_ALERTE=5
